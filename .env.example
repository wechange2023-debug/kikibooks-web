# =============================================================================
# Kikibooks 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env.local 로 복사 (cp .env.example .env.local)
#   2. 아래 빈 값에 실제 키를 채워 넣기
#   3. .env.local 은 절대 git에 커밋되지 않음 (.gitignore 처리됨)
#
# ★ claude.md 2절 Hard Rule 6
#   SUPABASE_SERVICE_ROLE_KEY 는 절대 클라이언트 코드 / 공개 환경변수에 노출 금지.
#   NEXT_PUBLIC_ 접두사가 없는 점에 주의.
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
