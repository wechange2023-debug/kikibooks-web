# Dependencies
node_modules/
.pnpm-store/

# Next.js build output
.next/
out/
build/
dist/

# 예외: OCR 초벌 산출물은 커밋 대상 (ADR-0039 D5 bbox 보존 — 전역 out/ 규칙의 예외)
!scripts/ocr_pilot/out/
!scripts/ocr_pilot/out/**

# 예외: TTS 파일럿 정본 json은 커밋 대상 (안건 #3·#4 정답지 — 전역 out/ 규칙의 예외).
# 폴더 예외 후 audio·.tts.json 재무시 → 순수 {slug}.json 49개만 통과
!scripts/tts_pilot/out/
scripts/tts_pilot/out/audio/
scripts/tts_pilot/out/*.tts.json

# Vercel
.vercel/

# Environment ★ 보안: 절대 커밋 금지 (Hard Rule 6 — service_role 키 보호)
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/*.local.json

# TypeScript
*.tsbuildinfo

# Python (스크립트 캐시·로컬 산출물 — scripts/out/ 은 위 out/ 규칙에도 잡히나 명시)
__pycache__/
*.pyc
scripts/out/

# Tests / coverage
coverage/

# Misc
.tmp_init_path
*.pem

# Phase 진단 임시 파일 (수치는 ADR-0014 §2에 텍스트 박제 — 파일은 재현 가능, gitignore)
gdl_sample_diag.json
bookdash_meta_diag.yml
dry_run_*.txt

# STEP 3 표지 변환물 (ADR-0032) — 206장 webp, 버킷에 실물 업로드 완료. 재현 가능.
scratchpad/step3_out/

# Prong-2 검수 뷰어 렌더 산출물 (ADR-0043) — build_review.py로 재생성 가능, 용량 큼
scripts/pdf_harvest/review_viewer/img/
scripts/pdf_harvest/review_viewer/review.html
