#!/usr/bin/env bash
# HelloKiki pre-push guard — ADR-0040
# 활성 gh 계정이 crspiegel이 아니면 push를 차단한다(fail-closed).
# 우회가 꼭 필요하면 git push --no-verify (예외 상황 기록 후에만).

set -euo pipefail

EXPECTED="crspiegel"

# gh 미설치 시: 계정 확인 불가 → fail-closed로 차단하고 원인 안내
if ! command -v gh >/dev/null 2>&1; then
  echo "[pre-push 차단] gh CLI를 찾을 수 없습니다. 계정 확인 불가." >&2
  echo "  gh 설치 후 다시 시도하거나, 확인했다면 --no-verify로 우회하세요." >&2
  exit 1
fi

# 활성 계정 판별: 로컬 keyring 조회(오프라인 작동). 네트워크 호출 안 함.
ACTIVE="$(gh auth status --active 2>/dev/null | grep -oE 'account [^ ]+' | awk '{print $2}' | head -1 || true)"

if [ -z "$ACTIVE" ]; then
  echo "[pre-push 차단] 활성 gh 계정을 판별하지 못했습니다." >&2
  echo "  gh auth status 를 직접 확인하세요." >&2
  exit 1
fi

if [ "$ACTIVE" != "$EXPECTED" ]; then
  echo "[pre-push 차단] 활성 gh 계정이 '$ACTIVE' 입니다. '$EXPECTED' 여야 합니다." >&2
  echo "  해결: gh auth switch --user $EXPECTED  실행 후 다시 push." >&2
  exit 1
fi

echo "[pre-push] 활성 계정 확인: $ACTIVE ✅"
exit 0
